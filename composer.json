{
    "name": "mkakpabla/sms-gateway",
    "description": "Framework-agnostic SMS gateway with multi-provider fallback support",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "mkakpabla",
            "email": "mkakpabla@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpmd/phpmd": "^2.15",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "suggest": {
        "illuminate/notifications": "Required for Laravel notification channel integration",
        "illuminate/support": "Required for Laravel service provider auto-discovery"
    },
    "autoload": {
        "psr-4": {
            "SmsGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmsGateway\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SmsGateway\\Laravel\\SmsGatewayServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=256M",
        "phpmd": "phpmd src text phpmd.xml",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "quality": [
            "@phpstan",
            "@phpmd",
            "@phpcs"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
